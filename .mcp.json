{
  "mcpServers": {
    "notebook": {
      "command": "npx",
      "args": [
        "-y",
        "git+https://github.com/gemini-cli-extensions/data-agent-kit-starter-pack.git",
        "--mode=notebook"
      ],
      "env": {},
      "env_vars": [
        "DATA_CLOUD_CURR_IDE_NAME"
      ]
    },
    "visualization": {
      "command": "npx",
      "args": [
        "-y",
        "git+https://github.com/gemini-cli-extensions/data-agent-kit-starter-pack.git",
        "--mode=visualization"
      ],
      "env": {},
      "env_vars": [
        "DATA_CLOUD_CURR_IDE_NAME"
      ]
    },
    "datacloud_bigquery_toolbox": {
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "bigquery",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.codex"
      ],
      "env": {
        "BIGQUERY_LOCATION": "",
        "BIGQUERY_PROJECT": ""
      }
    },
    "datacloud_spanner_toolbox": {
      "command": "npx",
